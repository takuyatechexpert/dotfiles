# Claude Code 環境変数テンプレート
# このファイルを ~/.claude/.env にコピーして値を設定してください
# cp ~/dotfiles/packages/claude/.claude/env-template ~/.claude/.env

# ====================================
# Backlog
# ====================================
BACKLOG_API_KEY=                        # Backlog > 個人設定 > API

# ====================================
# Slack Channel IDs
# ====================================
# Slack チャンネルの URL から /C で始まる ID を取得
SLACK_CHANNEL_**=                      # チャンネル名

# ====================================
# Slack User IDs
# ====================================
# Slack プロフィール > 「…」メニュー > メンバーIDをコピー
SLACK_USER_***=             # ユーザー名
