#!/bin/sh

set -e

for i in "$@"; do
	case "$i" in
		-s|--skip-apps)
			skip_apps=1
			shift ;;
		*) ;;
	esac
done

# brew install
if [ ! -f /usr/local/bin/brew ]; then
	/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# dotfiles clone
if [ ! -d ~/dotfiles ]; then
	cd ~
	git clone git@github.com:takuyatechexpert/dotfiles.git
fi

# brew bundle
if [ ! "$skip_apps" ]; then
	brew bundle -v --file=~/dotfiles/Brewfile
fi

# starship.tomlのディレクトリ
if [ ! -d ~/.config ]; then
	mkdir ~/.config
fi

stow -v -d ~/dotfiles/packages -t ~ zsh vim neovim starship mise tmux wezterm hammerspoon yazi

# mise: install runtimes from .tool-versions
mise install

# Claude Code
mise use --global npm:@anthropic-ai/claude-code

# claude-code-settings: Claude Code 個人設定（rules/hooks/agents/skills/settings.json 等）
if [ -f ~/private-projects/claude-code-settings/install.sh ]; then
	sh ~/private-projects/claude-code-settings/install.sh
fi

# work-claude: 業務専用スキルのシンボリックリンクを設定
if [ -f ~/projects/work-claude/install.sh ]; then
	sh ~/projects/work-claude/install.sh
fi

